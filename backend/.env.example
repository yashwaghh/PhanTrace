# Required environment variables for the PhanTrace backend.
# Copy this file to .env and fill in your values before running locally.

# PostgreSQL connection string (Cloud SQL or any Postgres-compatible URL)
DATABASE_URL=postgresql://user:password@host:5432/phantrace?sslmode=require

# SerpAPI key – used for reverse-image / web search detections
SERPAPI_KEY=your_serpapi_key_here
